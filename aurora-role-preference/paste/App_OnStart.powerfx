            {Label:"Rank 2 · Stakeholder Management", Text:"Managed supplier relationships for the flood programme, including monthly contract review meetings."}
        )
    },
    {
        Id:2, Name:"L. Chen", Grade:"SG6", Area:"Yorkshire", Date:"22/06/2026", Stage2:"Outstanding", Status:"Submitted",
        Roles: Table({Order:1,RoleName:"Performance & Reporting Control"},{Order:2,RoleName:"Risk & Dependency Management"}),
        Answers: Table()
    },
    {
        Id:3, Name:"D. Martinez", Grade:"SG5", Area:"East Anglia", Date:"23/06/2026", Stage2:"Submitted", Status:"Withdrawn",
        Roles: Table({Order:1,RoleName:"Stakeholder Management"},{Order:2,RoleName:"Governance & Decision Support"}),
        Answers: Table(
            {Label:"Rank 1 · Stakeholder Management", Text:"Led stakeholder engagement for coastal schemes across multiple authorities."},
            {Label:"Rank 2 · Governance & Decision Support", Text:"Supported decision logs and assurance reviews for the area portfolio."}
        )
    },
    {
        Id:4, Name:"T. Jackson", Grade:"G7", Area:"Thames", Date:"23/06/2026", Stage2:"Submitted", Status:"Submitted",
        Roles: Table({Order:1,RoleName:"Resource Management"},{Order:2,RoleName:"Governance & Decision Support"}),
        Answers: Table(
            {Label:"Rank 1 · Resource Management", Text:"Planned resource demand for a 40-strong delivery team using a rolling capacity model."},
