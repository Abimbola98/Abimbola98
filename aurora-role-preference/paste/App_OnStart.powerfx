/* ===================================================================
   1) IDENTITY  — replace the literal record with the People lookup:
      Set(varUser, LookUp(People, 'Email/UPN' = User().Email))
   =================================================================== */
Set(
    varUser,
    {
        Name: "S. Patel",
        EmpId: "60412",
        Grade: "SG6",
        Area: "Devon, Cornwall & Isles of Scilly",
        Team: "Area Programme",
        LastLogin: "24/06/2026 09:14"
    }
);

/* ADMIN GATE — stub. Wire to the real Office365Groups / config check, e.g.
   Set(varIsAdmin, !IsBlank(LookUp(Office365Groups.ListOwnedGroupsV2()...)))
   NOTE: in-app gating is NOT security — enforce row-level security on the
   Dataverse tables too (see README). */
Set(varIsAdmin, true);

/* ===================================================================
   2) ROLES  ->  Dataverse table: Roles
      Nested Responsibilities/Requirements are stored as inline tables so
      the detail-screen galleries can bind to them. In Dataverse these are
      rich-text / multiline fields — split on import as needed.
   =================================================================== */
ClearCollect(
    colRoles,
    {
        Key: "gov", Name: "Governance & Decision Support",
        Desc: "Boards, decisions and portfolio governance.", Full: true,
        Purpose: "Supports portfolio governance, decision-making boards and assurance of EA project delivery.",
        Responsibilities: Table({Item:"Board secretariat and preparation"},{Item:"Tracking decisions and actions"},{Item:"Supporting senior reporting"},{Item:"Liaison with delivery and finance teams"}),
        Requirements: Table({Item:"Experience of governance or PMO environments"},{Item:"Strong written communication"},{Item:"Comfort working with senior stakeholders"},{Item:"Attention to detail"}),
        GradeContext: "Typically SG6."
    },
    {
        Key: "perf", Name: "Performance & Reporting Control",
        Desc: "Delivery confidence, reporting and data management.", Full: true,
        Purpose: "Provides delivery confidence, performance reporting and data management across the area portfolio.",
        Responsibilities: Table({Item:"Producing portfolio performance and delivery-confidence reporting"},{Item:"Maintaining benefits and milestone trackers"},{Item:"Managing programme data quality and management information"},{Item:"Supporting forecasting and trend analysis for senior reviews"}),
        Requirements: Table({Item:"Strong analytical and data-handling skills"},{Item:"Confident with reporting tools and spreadsheets"},{Item:"Clear presentation of performance information"},{Item:"Attention to accuracy and detail"}),
        GradeContext: "Typically SG6."
    },
    {
        Key: "stake", Name: "Stakeholder Management",
        Desc: "Supplier and stakeholder relationships.", Full: true,
        Purpose: "Manages the supplier and stakeholder relationships that underpin successful delivery.",
        Responsibilities: Table({Item:"Building and maintaining key stakeholder and supplier relationships"},{Item:"Coordinating engagement and communications activity"},{Item:"Running contract and supplier review meetings"},{Item:"Resolving issues and escalations with delivery partners"}),
        Requirements: Table({Item:"Excellent interpersonal and communication skills"},{Item:"Experience managing external relationships"},{Item:"Negotiation and influencing ability"},{Item:"Comfort working across organisational boundaries"}),
        GradeContext: "Typically SG6."
    },
    {
        Key: "risk", Name: "Risk & Dependency Management",
        Desc: "Risk, issue and dependency registers.", Full: true,
        Purpose: "Maintains the risk, issue and dependency picture across the programme.",
        Responsibilities: Table({Item:"Maintaining risk, issue and dependency registers"},{Item:"Facilitating risk reviews and mitigation planning"},{Item:"Tracking cross-team dependencies"},{Item:"Reporting the risk position to governance boards"}),
        Requirements: Table({Item:"Experience of risk or PMO processes"},{Item:"Structured, methodical approach"},{Item:"Strong facilitation skills"},{Item:"Attention to detail"}),
        GradeContext: "Typically SG6 to SG5."
    },
    {
        Key: "res", Name: "Resource Management",
        Desc: "Resource demand and workload planning.", Full: true,
        Purpose: "Plans resource demand and balances workload across competing priorities.",
        Responsibilities: Table({Item:"Planning and forecasting resource demand"},{Item:"Balancing workload across teams and priorities"},{Item:"Maintaining capacity and allocation models"},{Item:"Supporting recruitment and onboarding planning"}),
        Requirements: Table({Item:"Experience of resource or capacity planning"},{Item:"Strong organisational skills"},{Item:"Confident with planning tools and data"},{Item:"Ability to manage competing demands"}),
        GradeContext: "Typically SG6 to G7."
    }
);

/* ===================================================================
   3) ROLE QUESTIONS  ->  Dataverse table: RoleQuestions
      Two role-specific questions per role (Order 1 & 2). The third Stage-2
      question ("Why have you ranked this role as your first/second
      choice?") is generated per section in the colAnswers builder below.
   =================================================================== */
ClearCollect(
    colRoleQuestions,
    {RoleKey:"gov",  Order:1, Required:true, Text:"This role supports senior decision-making boards. Describe your experience preparing for or running governance boards."},
    {RoleKey:"gov",  Order:2, Required:true, Text:"What evidence shows your ability to manage portfolio-level governance and reporting?"},
    {RoleKey:"perf", Order:1, Required:true, Text:"This role focuses on delivery confidence, benefits tracking and data management. Describe relevant experience."},
    {RoleKey:"perf", Order:2, Required:true, Text:"Give an example of using performance data to influence a delivery decision."},
    {RoleKey:"stake",Order:1, Required:true, Text:"This role centres on supplier and stakeholder relationships. Describe your experience managing complex stakeholder relationships."},
    {RoleKey:"stake",Order:2, Required:true, Text:"Give an example of resolving a difficult supplier or stakeholder issue."},
    {RoleKey:"risk", Order:1, Required:true, Text:"This role maintains risk, issue and dependency registers. Describe your experience managing risks and dependencies on a programme."},
    {RoleKey:"risk", Order:2, Required:true, Text:"Give an example of identifying and mitigating a significant delivery risk."},
    {RoleKey:"res",  Order:1, Required:true, Text:"This role covers resource demand and workload planning. Describe your experience planning and balancing resource across competing demands."},
    {RoleKey:"res",  Order:2, Required:true, Text:"Give an example of managing a resourcing shortfall or conflict."}
);

/* SAMPLE ANSWERS — preview-only fallback shown on scrCompleted when a
   field was left blank. dc.html only defines samples for gov & perf. */
ClearCollect(
    colSampleAnswers,
    {RoleKey:"gov",  QIndex:0, Text:"I have prepared papers and provided secretariat support for monthly programme boards over the past three years, including agenda setting, action tracking and minutes."},
    {RoleKey:"gov",  QIndex:1, Text:"I currently maintain the portfolio decision log and produce the quarterly governance report used by the senior leadership team."},
    {RoleKey:"gov",  QIndex:2, Text:"It is the closest fit to my current responsibilities and where I can add value most quickly."},
    {RoleKey:"perf", QIndex:0, Text:"I have supported delivery confidence assessments and maintained benefits trackers for two large capital programmes."},
    {RoleKey:"perf", QIndex:1, Text:"I used milestone trend data to recommend re-sequencing two dependent workstreams, recovering roughly six weeks of float."},
    {RoleKey:"perf", QIndex:2, Text:"I am keen to build on my reporting experience and see this as a strong development step."}
);

/* ===================================================================
   4) ELIGIBILITY + WORKING RANKS  ->  Dataverse tables: Eligibility (set
      per person) joined to Roles. colRanks is the editable Stage-1 model
      and is the Items source for the scrForm gallery.
      Seeded with dc.html seed ranks [1,1,2,3,4] — note the DELIBERATE
      duplicate (gov & perf both = 1) to demonstrate validation.
      Count is per-person; do NOT hardcode five downstream.
   =================================================================== */
ClearCollect(
    colRanks,
    {RoleKey:"gov",  RoleName:"Governance & Decision Support", ShortDescription:"Boards, decisions and portfolio governance.",        Rank:1},
    {RoleKey:"perf", RoleName:"Performance & Reporting Control", ShortDescription:"Delivery confidence, reporting and data management.", Rank:1},
    {RoleKey:"stake",RoleName:"Stakeholder Management",          ShortDescription:"Supplier and stakeholder relationships.",            Rank:2},
    {RoleKey:"risk", RoleName:"Risk & Dependency Management",    ShortDescription:"Risk, issue and dependency registers.",              Rank:3},
    {RoleKey:"res",  RoleName:"Resource Management",             ShortDescription:"Resource demand and workload planning.",             Rank:4}
);

/* Recompute the Stage-1 error list. This exact block is reused verbatim
   in scrForm > galRoles > drpRank.OnChange (kept in sync by hand). */
ClearCollect(
    colFormErrors,
    ForAll(
        Filter(
            AddColumns(GroupBy(Filter(colRanks, Rank > 0), "Rank", "grp"), "cnt", CountRows(grp)),
            cnt > 1
        ),
        {Msg: "Rank " & Rank & " has been selected for more than one role. Each role must have a unique rank."}
    )
);
If(
    CountRows(Filter(colRanks, Rank = 0 Or IsBlank(Rank))) > 0,
    Collect(colFormErrors, {Msg: "Every role must be given a rank before you can submit."})
);

/* ===================================================================
   5) LOCKED RANKING (Stage 1 output)  ->  Dataverse table: Preferences
      Seeded here with the CANONICAL order [1,2,4,3,5] -> gov, perf, risk,
      stake, res, so scrReview / scrCompleted render content on first
      preview. The real flow rebuilds this from colRanks at Stage-1 lock.
   =================================================================== */
ClearCollect(
    colLockedRanking,
    {Rank:1, RoleKey:"gov",  RoleName:"Governance & Decision Support", ShortDescription:"Boards, decisions and portfolio governance."},
    {Rank:2, RoleKey:"perf", RoleName:"Performance & Reporting Control", ShortDescription:"Delivery confidence, reporting and data management."},
    {Rank:3, RoleKey:"risk", RoleName:"Risk & Dependency Management",    ShortDescription:"Risk, issue and dependency registers."},
    {Rank:4, RoleKey:"stake",RoleName:"Stakeholder Management",          ShortDescription:"Supplier and stakeholder relationships."},
    {Rank:5, RoleKey:"res",  RoleName:"Resource Management",             ShortDescription:"Resource demand and workload planning."}
);

/* ===================================================================
   6) STAGE-2 ANSWERS (top two only)  ->  Dataverse table:
      PreferenceResponses. Builder is generic: it reads the top two of
      colLockedRanking and pulls question text from colRoleQuestions, plus
      the per-section "why" question. Reused at Stage-1 lock (scrForm).
      Rows exist ONLY for Rank <= 2 (matches the data model).
   =================================================================== */
Clear(colAnswers);
ForAll(
    Sequence(2) As p,
    With(
        {
            row: Index(colLockedRanking, p.Value),
            ord: If(p.Value = 1, "first", "second"),
            lbl: If(p.Value = 1, "Top choice · Rank 1", "Second choice · Rank 2")
        },
        Collect(
            colAnswers,
            {RoleKey:row.RoleKey, RoleName:row.RoleName, Ordinal:ord, RankLabel:lbl, QIndex:0, Required:true, QuestionText: LookUp(colRoleQuestions, RoleKey=row.RoleKey And Order=1).Text, Answer:""},
            {RoleKey:row.RoleKey, RoleName:row.RoleName, Ordinal:ord, RankLabel:lbl, QIndex:1, Required:true, QuestionText: LookUp(colRoleQuestions, RoleKey=row.RoleKey And Order=2).Text, Answer:""},
            {RoleKey:row.RoleKey, RoleName:row.RoleName, Ordinal:ord, RankLabel:lbl, QIndex:2, Required:true, QuestionText: "Why have you ranked this role as your " & ord & " choice?", Answer:""}
        )
    )
);

/* ===================================================================
   7) ADMIN OVERVIEW  ->  Dataverse: Preferences + People + Eligibility +
      PreferenceResponses (joined). Seeded with the four dc.html rows.
      Nested Roles / Answers are inline tables for the row + expansion UI.
   =================================================================== */
ClearCollect(
    colOverviewRows,
    {
        Id:1, Name:"K. O'Brien", Grade:"SG6", Area:"Yorkshire", Date:"22/06/2026", Stage2:"Submitted", Status:"Submitted",
        Roles: Table({Order:1,RoleName:"Governance & Decision Support"},{Order:2,RoleName:"Stakeholder Management"},{Order:3,RoleName:"Resource Management"}),
